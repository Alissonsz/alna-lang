  "sourceLines": [
    "int games(int x) {",
    "   int a = x + 10",
    "   if a \u003e 20 {",
    "     int b = a - 5",
    "     __write(b)",
    "     return",
    "   }",
    "   __write(a)",
    "}",
    "",
    "int main () {",
    "  int a = 15",
    "  games(a)",
    "}",
    ""
